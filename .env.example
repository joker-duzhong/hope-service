# Hope Service 环境变量配置

# ==================== 基础配置 ====================
DEBUG=true

# ==================== 数据库配置 ====================
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=hope_service

# ==================== Redis 配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== JWT 配置 ====================
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== 微信公众号配置 ====================
WECHAT_APPS=wxappid1:your_secret1:your_token1:your_encoding_aes_key1,wxappid2:your_secret2:your_token2:your_encoding_aes_key2

# ==================== 飞书webhook ====================
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_id

# ==================== 端口配置 ====================
APP_PORT=8000
