# Hope Service 环境变量配置

# ==================== 基础配置 ====================
DEBUG=false

# ==================== 数据库配置 ====================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password
POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_DB=hope_service

# ==================== Redis 配置 ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== JWT 配置 ====================
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== 微信公众号配置 ====================
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# ==================== 外部服务配置 ====================
# SimpleTex 公式识别
SIMPLETEX_API_URL=https://server.simpletex.cn
SIMPLETEX_API_TOKEN=your-simpletex-token

# ==================== 短信服务配置（预留） ====================
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
SMS_SIGN_NAME=

# ==================== 大模型配置（预留） ====================
# OpenAI
OPENAI_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# ==================== 端口配置 ====================
APP_PORT=8000
